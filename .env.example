NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Activity feature flags (server-side, set to 'false' to disable)
FEATURE_PICKEM_CREATION_ENABLED=true
FEATURE_PICKEM_PUBLISH_ENABLED=true
FEATURE_PICKEM_PARTICIPATION_ENABLED=true
FEATURE_PICKEM_MANAGE_EXISTING_ENABLED=true
FEATURE_PICKEM_READ_ENABLED=true

# Twitch OAuth for subscriber verification (custom OAuth flow)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TOKEN_ENCRYPTION_KEY=
